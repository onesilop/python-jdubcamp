{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run FastAPI app",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "jinja": true,
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    }
  ]
}
